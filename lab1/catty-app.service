[Unit]
Description=Catty Reminders App
After=network.target

[Service]
User=timoha
WorkingDirectory=/home/timoha/Desktop/devops/catty-reminders-app
ExecStart=/home/timoha/Desktop/devops/catty-reminders-app/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8181
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
